  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/schwarztim/copilot-proxy.git"
  },
  "bugs": {
    "url": "https://github.com/schwarztim/copilot-proxy/issues"
  },
  "homepage": "https://github.com/schwarztim/copilot-proxy#readme"
}
